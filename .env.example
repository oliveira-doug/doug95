# ── Variáveis de ambiente — Studio Íra Oliveira ─────────────────────────────
# Copie para .env.local (que NÃO vai pro git) e preencha. No Vercel, defina as
# mesmas chaves em Project → Settings → Environment Variables.
#
# Tudo aqui tem prefixo NEXT_PUBLIC_ = vai pro browser (público). NUNCA coloque
# segredo (service role, tokens) com esse prefixo.

# URL pública do site. Local pode deixar em branco (usa http://localhost:3000).
# Em produção, a URL real do deploy (sem barra no final).
#   ex.: https://studio-ira.vercel.app  ou  https://studioira.com.br
NEXT_PUBLIC_SITE_URL=

# ID da propriedade do Google Analytics 4 (formato G-XXXXXXXXXX).
# Crie em https://analytics.google.com → Admin → Fluxo de dados (Web).
# Sem este valor, o site funciona normal e simplesmente não mede nada.
NEXT_PUBLIC_GA_ID=

# ── Supabase (Fase 2 — Dashboard) ───────────────────────────────────────────
# Em supabase.com → seu projeto → Settings → API.
# URL e ANON KEY são públicas (vão ao browser). Já o SERVICE ROLE é SECRETO:
# bypassa o RLS (chave-mestra). NUNCA prefixe com NEXT_PUBLIC, nunca commite.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
